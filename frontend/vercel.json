{
  "version": 2,
  "rewrites": [
    { "source": "/about", "destination": "/backend/server.js" },
    { "source": "/why-ayurveda", "destination": "/backend/server.js" },
    { "source": "/profile", "destination": "/backend/server.js" },
    { "source": "/admin-portal", "destination": "/backend/server.js" },
    { "source": "/api/(.*)", "destination": "/backend/server.js" },
    { "source": "/contact", "destination": "/backend/server.js" },
    { "source": "/(.*)", "destination": "/frontend/$1" },
    { "source": "/", "destination": "/frontend/index.html" }
  ]
}