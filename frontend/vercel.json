{
  "version": 2,
  "rewrites": [
    { 
      "source": "/(about|why-ayurveda|profile|contact|admin-portal)", 
      "destination": "/backend/server.js" 
    },
    { 
      "source": "/(.*)", 
      "destination": "/frontend/$1" 
    },
    { 
      "source": "/", 
      "destination": "/frontend/index.html" 
    }
  ]
}