<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>About Us | NIVORGO</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Montserrat:wght@300;400;600&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/style.css"> </head>
<body>

    <%- include('navbar') %>

    <header class="text-center text-white d-flex align-items-center justify-content-center" style="background-color: #4A5D45; height: 60vh; margin-top: 0;">
        <div data-aos="fade-up">
            <h1 class="display-3 font-serif">Our Story</h1>
            <p class="lead">Rooted in Tradition. Crafted for You.</p>
        </div>
    </header>

    <section class="section py-5">
        <div class="container py-5">
            <div class="row align-items-center">
                <div class="col-lg-6 mb-4">
                    <h2 class="font-serif mb-4" style="color: #4A5D45;">The Nivorgo Standard</h2>
                    <p class="lead text-muted">We believe that true wellness comes from nature, not a laboratory.</p>
                    <p>Nivorgo was founded in Pune with a simple mission: to make the 5,000-year-old wisdom of Ayurveda accessible to the modern world without compromising on purity.</p>
                    <p>Every bottle we produce is free from harsh chemicals, sulfates, and parabens.</p>
                </div>
                <div class="col-lg-6">
                    <img src="/assets/background.jpeg" class="img-fluid rounded shadow" alt="About Nivorgo">
                </div>
            </div>
        </div>
    </section>

    <%- include('footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>