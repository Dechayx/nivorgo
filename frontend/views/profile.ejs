<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Profile | NIVORGO</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
    <style>
        .profile-card { border-radius: 15px; border: none; box-shadow: 0 4px 20px rgba(0,0,0,0.08); }
        .order-badge { font-size: 0.75rem; padding: 5px 12px; border-radius: 20px; }
    </style>
</head>
<body class="bg-light">

    <%- include('navbar') %>

    <div class="container" style="margin-top: 120px; margin-bottom: 60px;">
        <div class="row g-4">
            <div class="col-lg-4">
                <div class="card profile-card p-4 mb-4">
                    <h4 class="font-serif mb-4" style="color: #4A5D45;">Profile Details</h4>
                    <div class="mb-3">
                        <label class="text-muted small">Full Name</label>
                        <p id="profile-name" class="fw-bold mb-0">Loading...</p>
                    </div>
                    <div class="mb-4">
                        <label class="text-muted small">Email Address</label>
                        <p id="profile-email" class="mb-0">Loading...</p>
                    </div>
                    <hr>
                    <h5 class="font-serif mb-3">Saved Address</h5>
                    <div id="address-display">
                        <p id="profile-address" class="small text-muted">No address saved yet.</p>
                    </div>
                    <button class="btn btn-sm btn-outline-success mt-3" data-bs-toggle="modal" data-bs-target="#editProfileModal">Edit Profile</button>
                </div>
            </div>

            <div class="col-lg-8">
                <div class="card p-4 shadow-sm">
    <h4 class="font-serif mb-4">Order History</h4>
    <div class="table-responsive">
        <table class="table">
            <thead>
                <tr>
                    <th>Order ID</th>
                    <th>Date</th>
                    <th>Status</th>
                    <th>Total</th>
                    <th>Items</th>
                </tr>
            </thead>
            <tbody id="orders-tbody">
                <tr><td colspan="5" class="text-center">Loading orders...</td></tr>
            </tbody>
        </table>
    </div>
</div>
        </div>
    </div>

    <div class="modal fade" id="editProfileModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title font-serif">Update Profile</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form id="editProfileForm">
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Street Address</label>
                            <input type="text" id="edit-street" class="form-control" required>
                        </div>
                        <div class="row">
                            <div class="col-6 mb-3">
                                <label class="form-label">City</label>
                                <input type="text" id="edit-city" class="form-control" required>
                            </div>
                            <div class="col-6 mb-3">
                                <label class="form-label">Zip Code</label>
                                <input type="text" id="edit-zip" class="form-control" required>
                            </div>
                        </div>
                        <div class="col-6 mb-3">
    <label class="form-label">Mobile Number</label>
    <input type="tel" 
           id="edit-mobile" 
           class="form-control" 
           maxlength="10" 
           pattern="\d{10}" 
           placeholder="Enter 10 digits"
           oninput="this.value = this.value.replace(/[^0-9]/g, '');" 
           required>
</div>
                    </div>
                    <div class="modal-footer">
                        <button type="submit" class="btn btn-success">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <%- include('footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/main.js"></script>
</body>
</html>